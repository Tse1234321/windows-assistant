# Dependencies
node_modules/

# Environment / secrets
.env
.env.*
!.env.example

# Build output
dist/
out/
release/
release-auto/
release-auto-*/
win-unpacked/
.git_corrupt_backup_*/

# Test coverage
coverage/

# Playwright
test-results/
playwright-report/
.playwright/

# Generated icons (regenerated via `npm run gen:icons`)
build/icon.png
electron/assets/tray-icon.png
scripts/3d/generated/

# Code-signing credentials must only come from a secure local/CI secret store.
*.pfx
*.p12
*.pem
*.key

# Logs
npm-debug.log*
*.log

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local runtime state (written by the app at runtime)
config/runtime-state.json

# Real settings file — written by the app in dev and contains personal paths.
# A sanitized template is committed as config/user-settings.example.json instead.
config/user-settings.json

# Local security settings and reputation/hash caches. These may contain secrets
# or machine-specific scan metadata and must never be committed.
securitySettings.json
securityReputationCache.json
cleanupHashCache.json
**/securitySettings.json
**/securityReputationCache.json
**/cleanupHashCache.json
